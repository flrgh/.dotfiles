#!/usr/bin/env bash

set -euo pipefail

shopt -s nullglob

declare -g -r SESSION_DIR="$HOME"/.config/tmux/up.d
declare -g -r SAVED="$SESSION_DIR"/99-saved

# all sessions that are not managed by the `save` command
declare -g -A MANAGED_SESSIONS=()
# all sessions that _are_ managed by the `save` command
declare -g -A SAVED_SESSIONS=()

declare -g -i RECORD_ONLY=0
declare -g USER_FILE

create-session() {
    local name=${1:?}
    local dir=${2:?}

    if [[ $USER_FILE == "$SAVED" ]]; then
        SAVED_SESSIONS[$name]=$dir
    else
        MANAGED_SESSIONS[$name]=$dir
    fi

    if (( RECORD_ONLY )); then
        return
    fi

    if tmux has-session -t "$name" &>/dev/null; then
        echo "session $name already exists"
        return
    fi

    tmux new-session \
        -s "$name" \
        -c "$dir" \
        -d

    echo "session $name created"
}

source_all() {
    for USER_FILE in "$SESSION_DIR"/*; do
        # shellcheck disable=SC1090
        source "$USER_FILE"
    done
}

up() {
    RECORD_ONLY=0
    source_all
}

save() {
    local -i prune=0

    while (( $# > 0 )); do
        case $1 in
            --prune|-p)
                prune=1;;
            *)
                printf 'save: unknown argument: %s\n' "$1" >&2
                return 1;;
        esac
        shift
    done

    # populate MANAGED_SESSIONS and SAVED_SESSIONS without creating anything
    RECORD_ONLY=1
    source_all
    RECORD_ONLY=0

    local -A out=()
    if (( ! prune )); then
        for name in "${!SAVED_SESSIONS[@]}"; do
            out[$name]=${SAVED_SESSIONS[$name]}
        done
    fi

    local name dir
    while IFS=$'\t' read -r name dir; do
        if [[ -z ${name:-} || -n ${MANAGED_SESSIONS[$name]:-} ]]; then
            continue
        fi
        out[$name]=$dir
    done < <(tmux list-sessions -F $'#{session_name}\t#{session_path}' 2>/dev/null)

    mkdir -p "$SESSION_DIR"

    echo "# generated by 'tu save' -- do not edit" > "$SAVED"
    for name in "${!out[@]}"; do
        printf 'create-session %q %q\n' "$name" "${out[$name]}" >> "$SAVED"
    done

    echo "saved ${#out[@]} session(s) to $SAVED"
}

usage() {
    cat <<EOF
tu -- bring up and save tmux sessions

usage:
  tu [up]            create every configured session (default)
  tu save [--prune]  record active sessions to the saved file
  tu -h | --help     show this help

Sessions are defined by files in
  $SESSION_DIR/
that are sourced as bash and call:
  create-session <name> <default-cwd>

'tu save' records active sessions (a name + default cwd) into
  $SAVED
so the next 'tu up' recreates them. Sessions already produced by a
hand-written file are left out. With --prune, sessions that are no
longer active are dropped from the saved file.
EOF
}

main() {
    local arg
    for arg in "$@"; do
        case $arg in
            -h|--help|help)
                usage
                return 0;;
        esac
    done

    local cmd=up
    if (( $# > 0 )); then
        cmd=$1
        shift
    fi

    tmux start-server

    case $cmd in
        save)
            save "$@";;

        up)
            up "$@";;

        *)
            printf 'tu: unknown command: %s\n\n' "$cmd" >&2
            usage >&2
            return 1;;
    esac
}

main "$@"
