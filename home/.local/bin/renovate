#!/usr/bin/env bash

# 1. renovate can't run on npm >24
# 2. mise can't have per-tool node versions
#
# so here we are

export RENOVATE_X_IGNORE_RE2=true

exec \
    secrets exec --cache \
    --env RENOVATE_TOKEN=bws://main/github-readonly-pat \
    --env RENOVATE_GITHUB_COM_TOKEN=bws://main/github-readonly-pat \
    -- \
    mise exec --env renovate \
    -- \
    renovate "$@"
