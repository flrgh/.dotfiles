$(DEP)/bash-completion: $(DEP_INSTALLED)/.bash-completion-cleanup

$(DEP_INSTALLED)/.bash-completion-cleanup: $(DEP_INSTALLED)/bash-completion
	$(SCRIPT)/cleanup-bash-completion
	@$(TOUCH) --reference "$<" "$@"

$(eval $(call comp_command,ast-grep,ast-grep completions bash))
$(eval $(call comp_complete,aws,$$(shell $$(MISE) which aws_completer),aws-cli))
$(eval $(call comp_command,bat,bat --completion bash))
$(eval $(call comp_command,bazel,$$(SCRIPT)/download-bazel-bash-completion))
$(eval $(call comp_command,bindgen,bindgen --generate-shell-completions bash DUMMY_HEADER_FILE_ARG,bindgen-cli))
$(eval $(call comp_url,busted,https://raw.githubusercontent.com/Olivine-Labs/busted/master/completions/bash/busted.bash))
$(eval $(call comp_command,bws,bws completions bash))
$(eval $(call comp_command,cargo,rustup completions bash cargo,rust-init))
$(eval $(call comp_command,delta,delta --generate-completion bash))
$(eval $(call comp_command,docker-language-server,docker-language-server completion bash))
$(eval $(call comp_candidate_list,files-in-package,ls-packages --name-only))
$(eval $(call comp_command,gh,gh completion --shell bash))
$(eval $(call comp_command,gh-helper,gh-helper generate-bash-completion))
$(eval $(call comp_file,git-cliff,$$(wildcard $$(shell $$(MISE) where git-cliff)/*/completions)/git-cliff.bash,git-cliff))
$(eval $(call comp_command,ineed,ineed _bash_completion))
$(eval $(call comp_command,kubectl,kubectl completion bash))
$(eval $(call comp_command,luarocks,luarocks completion bash,luarocks))
$(eval $(call comp_command,minijinja-cli,minijinja-cli --generate-completion bash))
$(eval $(call comp_command,mise,mise completion bash))
$(eval $(call comp_command,opencode,opencode completion))
$(eval $(call comp_candidate_list,package-deps,ls-packages --name-only))
$(eval $(call comp_candidate_list,package-info,ls-packages --name-only))
$(eval $(call comp_candidate_list,package-rdeps,ls-packages --name-only))
$(eval $(call comp_command,pip,pip completion --bash,python))
$(eval $(call comp_command,pip3,pip3 completion --bash,python))
$(eval $(call comp_command,rg,$$(MISE) exec ripgrep -- rg --generate complete-bash,ripgrep))
$(eval $(call comp_command,rustup,rustup completions bash rustup,rust-init))
$(eval $(call comp_command,secrets,secrets completions bash))
$(eval $(call comp_command,sg,sg completions bash,ast-grep))
$(eval $(call comp_command,tea,tea completion bash))
$(eval $(call comp_command,tree-sitter,tree-sitter complete --shell bash))
$(eval $(call comp_command,usage,usage --completions bash))
$(eval $(call comp_command,wasmtime,wasmtime completion bash,wasmtime-cli))
$(eval $(call comp_command,yq,yq shell-completion bash))
$(eval $(call comp_command,pnpm,pnpm completion bash))
